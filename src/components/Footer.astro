---
import { SITE_TITLE } from "../consts";

const today = new Date();
---

<footer>
  <p>&copy; {today.getFullYear()} {SITE_TITLE}</p>
</footer>

<style>
footer {
  padding: 2.5rem 1.5rem;
  background: var(--footer-bg, white);
  border-top: 1px solid var(--footer-border, rgb(var(--gray-light)));
  text-align: center;
}
footer p {
  margin: 0;
  font-size: 0.85rem;
  color: var(--footer-text, rgb(var(--gray)));
}
</style>
