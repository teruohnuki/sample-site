---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

export const prerender = true;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      ogImagePath="/og/index.png"
    />
  </head>
  <body>
    <Header />

    <div class="bg-glow" aria-hidden="true">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
      <div class="glow glow-3"></div>
    </div>

    <main>
      <!-- Hero -->
      <section class="hero">
        <div class="hero-logo"><img src="/logo.png" alt="irodoor"></div>
        <div class="hero-content">
          <p class="hero-label">IRODOOR</p>
          <h1 class="hero-title">
            イロドアの<br>
            ビジネス
          </h1>
          <p class="hero-sub">
            イロドアの事業と、私たちが目指すビジョンをお伝えします。
          </p>
        </div>
      </section>

      <!-- About -->
      <section class="about">
        <div class="grad-line"></div>
        <div class="section-inner">
          <p class="tag">ABOUT</p>
          <h2 class="section-title">イロドアについて</h2>
          <p class="section-text">
            昨日までと同じ景色が、もっと色鮮やかに見えたなら。<br>
            不可能だと思っていた扉を開けることができて前へ進めるなら。<br>
            株式会社イロドアは、あなたの日常に彩りを与え、新たな挑戦への扉を開くパートナーです。
          </p>
        </div>
      </section>

      <!-- Business -->
      <section class="business">
        <div class="grad-line"></div>
        <div class="section-inner">
          <p class="tag">BUSINESS</p>
          <h2 class="section-title">事業内容</h2>
          <ul class="card-list">
            <li class="card">
              <div
                class="card-img"
                style="background-image: url('/nail-salon.jpg')"
              ></div>
              <div class="card-body">
                <p class="card-num">01</p>
                <h3 class="card-title">ホスピタリティコンサルティング事業</h3>
                <p class="card-text">
                  美容サロン・小売店等のサービス業に対し、店舗オペレーション改善・人材育成・顧客満足度向上を目的としたコンサルティングを提供。20年以上の現場経験と、店長・チーフとしてのマネジメント実績に裏付けられた実践的なノウハウが強みです。
                </p>
              </div>
            </li>
            <li class="card">
              <div
                class="card-img"
                style="background-image: url('/room.jpg')"
              ></div>
              <div class="card-body">
                <p class="card-num">02</p>
                <h3 class="card-title">不動産サブリース事業</h3>
                <p class="card-text">
                  サブリース（一括借上）による家賃保証で、空室や滞納リスクの不安を解消し、長期にわたる安定収入を実現します。物件管理やクレーム対応、建物管理まで煩わしい賃貸経営の全てをワンストップで代行。オーナー様は手間のかかる業務から解放され、安心して資産運用に専念していただけます。
                </p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <!-- Contact CTA -->
      <section class="contact">
        <div class="grad-line"></div>
        <div class="section-inner">
          <p class="tag">CONTACT</p>
          <h2 class="section-title">お問い合わせ</h2>
          <p class="section-text">
            事業に関するご質問・ご相談はお気軽にどうぞ。
          </p>
          <a href="mailto:irodoor2024@gmail.com" class="cta-btn"
            >メールで問い合わせる</a
          >
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
@import url("https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz@0,6..96;1,6..96&display=swap");

:global(html) {
  background: #080808;
}
:global(body) {
  background: #080808;
  color: #f0ece4;
}
:global(:root) {
  --header-bg: #080808;
  --header-border: rgba(255, 255, 255, 0.06);
  --header-text: #fff;
  --nav-text: rgba(255, 255, 255, 0.5);
  --nav-text-active: #fff;
  --nav-accent: #ec4899;
  --footer-bg: #080808;
  --footer-border: rgba(255, 255, 255, 0.05);
  --footer-text: rgba(255, 255, 255, 0.28);
}

/* Background glow orbs */
.bg-glow {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}
.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
}
.glow-1 {
  width: 550px;
  height: 550px;
  background: #f97316;
  opacity: 0.07;
  top: -180px;
  right: -120px;
}
.glow-2 {
  width: 420px;
  height: 420px;
  background: #ec4899;
  opacity: 0.06;
  bottom: 25%;
  left: -130px;
}
.glow-3 {
  width: 380px;
  height: 380px;
  background: #6366f1;
  opacity: 0.06;
  top: 55%;
  right: 8%;
}

main {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

/* Gradient section divider */
.grad-line {
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(249, 115, 22, 0.4) 25%,
    rgba(236, 72, 153, 0.4) 50%,
    rgba(99, 102, 241, 0.4) 75%,
    transparent
  );
}

/* Entrance animations */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(22px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Hero */
.hero {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rem;
  padding: 6rem 2rem 2rem;
  max-width: 960px;
  margin: 0 auto;
}
.hero-logo {
  flex: 0 0 auto;
  width: clamp(120px, 18vw, 200px);
  animation: fadeUp 1s ease both;
  filter: drop-shadow(0 0 48px rgba(249, 115, 22, 0.22))
    drop-shadow(0 0 24px rgba(236, 72, 153, 0.15));
}
.hero-logo img {
  width: 100%;
  height: auto;
  display: block;
}
.hero-content {
  display: flex;
  flex-direction: column;
}
.hero-label {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 1rem;
  letter-spacing: 0.2em;
  background: linear-gradient(135deg, #f97316, #ec4899, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  margin: 0 0 1.5rem 0;
  animation: fadeUp 1s ease both;
  animation-delay: 0.1s;
}
.hero-title {
  font-size: clamp(2.5rem, 8vw, 5.5rem);
  font-weight: 700;
  line-height: 1.1;
  color: #fff;
  margin: 0 0 1.75rem 0;
  letter-spacing: -0.02em;
  animation: fadeUp 1s ease both;
  animation-delay: 0.22s;
}
.hero-sub {
  font-size: 1rem;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.5);
  margin: 0;
  max-width: 480px;
  animation: fadeUp 1s ease both;
  animation-delay: 0.38s;
}

/* Sections */
.about,
.business,
.contact {
  padding: 6rem 2rem;
}
.section-inner {
  max-width: 960px;
  margin: 0 auto;
}
.tag {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 0.82rem;
  letter-spacing: 0.22em;
  background: linear-gradient(135deg, #f97316, #ec4899, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  margin: 0 0 1.25rem 0;
  display: inline-block;
}
.section-title {
  font-size: clamp(1.6rem, 4vw, 2.5rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 1.5rem 0;
  letter-spacing: -0.01em;
}
.section-text {
  font-size: 1rem;
  line-height: 2;
  color: rgba(255, 255, 255, 0.52);
  margin: 0;
  max-width: 560px;
}

/* Business cards */
.card-list {
  list-style: none;
  margin: 3rem 0 0 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
}
.card {
  background:
    linear-gradient(#0d0d0d, #0d0d0d) padding-box,
    linear-gradient(
      135deg,
      rgba(249, 115, 22, 0.22),
      rgba(236, 72, 153, 0.22),
      rgba(99, 102, 241, 0.22)
    )
    border-box;
  border: 1px solid transparent;
  border-radius: 16px;
  overflow: hidden;
  transition:
    transform 0.35s ease,
    box-shadow 0.35s ease;
}
.card:hover {
  transform: translateY(-6px);
  box-shadow:
    0 28px 72px rgba(0, 0, 0, 0.55),
    0 0 48px rgba(249, 115, 22, 0.08);
}
.card-img {
  width: 100%;
  height: 220px;
  background-size: cover;
  background-position: center;
  transition: transform 0.6s ease;
}
.card:hover .card-img {
  transform: scale(1.04);
}
.card-body {
  padding: 1.75rem;
}
.card-num {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 1.5rem;
  line-height: 1;
  background: linear-gradient(135deg, #f97316, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  margin: 0 0 0.75rem 0;
  display: inline-block;
}
.card-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 0.75rem 0;
}
.card-text {
  font-size: 0.88rem;
  line-height: 1.85;
  color: rgba(255, 255, 255, 0.45);
  margin: 0;
}

/* Contact CTA */
.cta-btn {
  display: inline-block;
  margin-top: 2rem;
  padding: 0.9rem 2.25rem;
  background: linear-gradient(135deg, #f97316, #ec4899);
  color: #fff;
  text-decoration: none;
  font-size: 0.92rem;
  font-weight: 600;
  border-radius: 999px;
  letter-spacing: 0.04em;
  transition:
    opacity 0.2s,
    transform 0.2s;
}
.cta-btn:hover {
  color: #fff;
  opacity: 0.82;
  transform: translateY(-2px);
}

@media (max-width: 640px) {
  .hero {
    flex-direction: column;
    align-items: flex-start;
    gap: 2rem;
    padding: 4rem 1.25rem 2rem;
  }
  .hero-logo {
    width: clamp(80px, 30vw, 120px);
  }
  .about,
  .business,
  .contact {
    padding: 4rem 1.25rem;
  }
  .card-list {
    grid-template-columns: 1fr;
  }
}
</style>
