---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";

export const prerender = true;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`会社概要 | ${SITE_TITLE}`}
      description="株式会社イロドアの会社概要ページです。"
    />
  </head>
  <body>
    <Header />

    <main>
      <section class="hero">
        <p class="hero-label">COMPANY</p>
        <h1 class="hero-title">会社概要</h1>
      </section>

      <section class="section">
        <div class="section-inner">
          <table class="info-table">
            <tbody>
              <tr>
                <th>商号</th>
                <td>株式会社イロドア</td>
              </tr>
              <tr>
                <th>法人番号</th>
                <td>2430001091357</td>
              </tr>
              <tr>
                <th>本店所在地</th>
                <td>
                  〒060-0005<br>北海道札幌市中央区南五条西１５丁目２－３<br>リズム医大前５０３号室
                </td>
              </tr>
              <tr>
                <th>設立</th>
                <td>令和6年3月15日</td>
              </tr>
            </tbody>
          </table>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
:global(html) {
  background: #0a0a0a;
}
:global(body) {
  background: #0a0a0a;
  color: #e8e8e8;
}
:global(:root) {
  --header-bg: #0a0a0a;
  --header-border: rgba(255, 255, 255, 0.08);
  --header-text: #fff;
  --nav-text: rgba(255, 255, 255, 0.6);
  --nav-text-active: #fff;
  --nav-accent: #7c6fff;
  --footer-bg: #0a0a0a;
  --footer-border: rgba(255, 255, 255, 0.06);
  --footer-text: rgba(255, 255, 255, 0.35);
}

main {
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

.hero {
  padding: 7rem 2rem 4rem;
  max-width: 960px;
  margin: 0 auto;
}
.hero-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #7c6fff;
  margin: 0 0 1.5rem 0;
}
.hero-title {
  font-size: clamp(2rem, 6vw, 3.5rem);
  font-weight: 700;
  color: #fff;
  margin: 0;
  letter-spacing: -0.02em;
  line-height: 1.1;
}

.section {
  padding: 4rem 2rem 8rem;
}
.section-inner {
  max-width: 960px;
  margin: 0 auto;
}

.info-table {
  width: 100%;
  border-collapse: collapse;
}
.info-table th,
.info-table td {
  padding: 1.25rem 1.5rem;
  text-align: left;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  font-size: 0.95rem;
  line-height: 1.8;
  vertical-align: top;
}
.info-table th {
  width: 160px;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.45);
  white-space: nowrap;
}
.info-table td {
  color: #e8e8e8;
}
.info-table tr:first-child th,
.info-table tr:first-child td {
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}

@media (max-width: 640px) {
  .hero {
    padding: 5rem 1.25rem 3rem;
  }
  .section {
    padding: 3rem 1.25rem 6rem;
  }
  .info-table th {
    width: 110px;
    font-size: 0.85rem;
  }
  .info-table td {
    font-size: 0.88rem;
  }
}
</style>
