---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";

export const prerender = true;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`代表紹介 | ${SITE_TITLE}`}
      description="株式会社イロドア 代表取締役 大貫 理の経歴・プロフィールページです。"
    />
  </head>
  <body>
    <Header />

    <div class="bg-glow" aria-hidden="true">
      <div class="glow glow-1"></div>
      <div class="glow glow-2"></div>
      <div class="glow glow-3"></div>
    </div>

    <main>
      <!-- Hero -->
      <section class="hero">
        <p class="hero-label">REPRESENTATIVE</p>
        <h1 class="hero-name"><span class="name-cursive">Aya Ohnuki</span></h1>
        <div class="name-accent"></div>
        <p class="hero-title">代表取締役 / 株式会社イロドア</p>
        <p class="hero-bio">
          アパレル及び美容業界において20年以上にわたり、プレイヤー・指導者・経営者の視点から実績を積む。2024年、株式会社イロドアを設立。ホスピタリティコンサルティング事業と不動産サブリース事業の二軸で事業を推進している。
        </p>
      </section>

      <!-- Career Timeline -->
      <section class="section">
        <div class="grad-line"></div>
        <div class="section-inner">
          <p class="tag">CAREER</p>
          <h2 class="section-title">職務経歴</h2>
          <ul class="timeline">
            <li class="tl-item">
              <p class="tl-period">2024年〜現在</p>
              <div class="tl-body">
                <p class="tl-company">株式会社イロドア</p>
                <p class="tl-role">代表取締役</p>
                <p class="tl-desc">
                  ホスピタリティコンサルティング事業・不動産サブリース事業を両輪に会社経営を推進。
                </p>
              </div>
            </li>
            <li class="tl-item">
              <p class="tl-period">2023年6月〜2024年5月</p>
              <div class="tl-body">
                <p class="tl-company">株式会社拓要 ネイルサロンアンドヴァ</p>
                <p class="tl-role">店長</p>
                <p class="tl-desc">
                  店舗全体の経営・運営管理、スタッフ育成、売上・予実管理を担当。
                </p>
              </div>
            </li>
            <li class="tl-item">
              <p class="tl-period">2009年5月〜2023年5月</p>
              <div class="tl-body">
                <p class="tl-company">株式会社シープール 等</p>
                <p class="tl-role">チーフネイリスト / 育成責任者</p>
                <p class="tl-desc">
                  銀座・麻布十番エリアにて勤務。後進の技術指導・育成を担い、高付加価値サービスを提供。
                </p>
              </div>
            </li>
            <li class="tl-item">
              <p class="tl-period">2001年3月〜2009年4月</p>
              <div class="tl-body">
                <p class="tl-company">株式会社ワールド 等</p>
                <p class="tl-role">アパレル販売</p>
                <p class="tl-desc">
                  アパレル業界での販売・接客を経験。ホスピタリティの基礎を培う。
                </p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <!-- Skills -->
      <section class="section">
        <div class="grad-line"></div>
        <div class="section-inner">
          <p class="tag">SKILLS</p>
          <h2 class="section-title">専門スキルと経験</h2>
          <ul class="skill-list">
            <li class="skill-card">
              <h3 class="skill-title">店舗経営・マネジメント</h3>
              <p class="skill-text">
                事業計画、売上・予実管理、人材マネジメント、マーケティング戦略の立案・実行。20年以上の現場経験から培った「おもてなし」の視点を経営に組み込み、スタッフ一人ひとりがホスピタリティを体現できる組織づくりを得意とする。顧客満足度と売上の両立を実現してきた実績を持つ。
              </p>
            </li>
            <li class="skill-card">
              <h3 class="skill-title">美容分野の専門性と指導力</h3>
              <p class="skill-text">
                銀座・麻布十番エリアでのチーフ経験。後進の技術指導・育成実績。ネイル・パーソナルカラー・アロマテラピーの知見を統合した高付加価値提案。複数の専門領域を掛け合わせることで、一人ひとりの顧客に寄り添ったトータルビューティ提案を実現。リピート率向上と顧客満足度の改善に貢献してきた実績を持つ。
              </p>
            </li>
            <li class="skill-card">
              <h3 class="skill-title">
                不動産運用・AI活用・総合コンサルティング
              </h3>
              <p class="skill-text">
                不動産サブリース事業で培った資産運用・管理ノウハウに加え、AIツールを積極的に活用した業務効率化を実践。複合的な視点からクライアントの課題を整理し、実行可能な解決策を提案する総合コンサルティング力を持つ。
              </p>
            </li>
          </ul>
        </div>
      </section>

      <!-- Qualifications -->
      <section class="section">
        <div class="grad-line"></div>
        <div class="section-inner">
          <p class="tag">QUALIFICATIONS</p>
          <h2 class="section-title">保有資格</h2>
          <ul class="qual-list">
            <li class="qual-group">
              <p class="qual-category">ネイル</p>
              <ul class="qual-items">
                <li>JNEネイリスト技能検定 1級</li>
                <li>JNAジェルネイル技能検定 上級</li>
              </ul>
            </li>
            <li class="qual-group">
              <p class="qual-category">カラー</p>
              <ul class="qual-items">
                <li>パーソナルカラリスト検定 2級</li>
                <li>色彩検定 2級</li>
              </ul>
            </li>
            <li class="qual-group">
              <p class="qual-category">その他</p>
              <ul class="qual-items">
                <li>AEAJアロマテラピー検定 1級</li>
              </ul>
            </li>
          </ul>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
@import url("https://fonts.googleapis.com/css2?family=Great+Vibes&family=Bodoni+Moda:ital,opsz@0,6..96;1,6..96&display=swap");

:global(html) {
  background: #080808;
}
:global(body) {
  background: #080808;
  color: #f0ece4;
}
:global(:root) {
  --header-bg: #080808;
  --header-border: rgba(255, 255, 255, 0.06);
  --header-text: #fff;
  --nav-text: rgba(255, 255, 255, 0.5);
  --nav-text-active: #fff;
  --nav-accent: #ec4899;
  --footer-bg: #080808;
  --footer-border: rgba(255, 255, 255, 0.05);
  --footer-text: rgba(255, 255, 255, 0.28);
}

/* Background glow orbs */
.bg-glow {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}
.glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(110px);
}
.glow-1 {
  width: 500px;
  height: 500px;
  background: #6366f1;
  opacity: 0.07;
  top: -150px;
  left: -100px;
}
.glow-2 {
  width: 400px;
  height: 400px;
  background: #ec4899;
  opacity: 0.06;
  top: 40%;
  right: -100px;
}
.glow-3 {
  width: 350px;
  height: 350px;
  background: #f97316;
  opacity: 0.05;
  bottom: 10%;
  left: 20%;
}

main {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

/* Gradient divider */
.grad-line {
  height: 1px;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(249, 115, 22, 0.4) 25%,
    rgba(236, 72, 153, 0.4) 50%,
    rgba(99, 102, 241, 0.4) 75%,
    transparent
  );
}

/* Entrance animations */
@keyframes fadeUp {
  from {
    opacity: 0;
    transform: translateY(22px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* Hero */
.hero {
  padding: 7rem 2rem 5rem;
  max-width: 960px;
  margin: 0 auto;
}
.hero-label {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 0.82rem;
  letter-spacing: 0.22em;
  background: linear-gradient(135deg, #f97316, #ec4899, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  margin: 0 0 1.75rem 0;
  display: inline-block;
  animation: fadeUp 1s ease both;
}
.hero-name {
  font-size: clamp(3rem, 10vw, 6rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 0.25rem 0;
  line-height: 1.1;
  animation: fadeUp 1s ease both;
  animation-delay: 0.12s;
}
.name-cursive {
  font-family: "Great Vibes", cursive;
  font-weight: 400;
  letter-spacing: 0.02em;
}
.name-accent {
  width: 64px;
  height: 2px;
  background: linear-gradient(90deg, #f97316, #ec4899, #6366f1);
  margin: 0.75rem 0 1.5rem;
  border-radius: 999px;
  animation: fadeUp 1s ease both;
  animation-delay: 0.22s;
}
.hero-title {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.38);
  margin: 0 0 2rem 0;
  letter-spacing: 0.04em;
  animation: fadeUp 1s ease both;
  animation-delay: 0.3s;
}
.hero-bio {
  font-size: 1rem;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.52);
  margin: 0;
  max-width: 600px;
  animation: fadeUp 1s ease both;
  animation-delay: 0.42s;
}

/* Sections */
.section {
  padding: 5rem 2rem;
}
.section-inner {
  max-width: 960px;
  margin: 0 auto;
}
.tag {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 0.82rem;
  letter-spacing: 0.22em;
  background: linear-gradient(135deg, #f97316, #ec4899, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  margin: 0 0 1.25rem 0;
  display: inline-block;
}
.section-title {
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 3rem 0;
  letter-spacing: -0.01em;
}

/* Timeline */
.timeline {
  list-style: none;
  margin: 0;
  padding: 0 0 0 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
}
.timeline::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.5rem;
  bottom: 0.5rem;
  width: 1px;
  background: linear-gradient(
    180deg,
    rgba(249, 115, 22, 0.5),
    rgba(236, 72, 153, 0.5),
    rgba(99, 102, 241, 0.5)
  );
}
.tl-item {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 2rem;
  padding: 2rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  position: relative;
}
.tl-item::before {
  content: "";
  position: absolute;
  left: -1.25rem;
  top: 2.4rem;
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: linear-gradient(135deg, #f97316, #ec4899);
  transform: translateX(-3px);
  box-shadow: 0 0 10px rgba(249, 115, 22, 0.5);
}
.tl-item:last-child {
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.tl-period {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 0.78rem;
  background: linear-gradient(135deg, #f97316, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  font-weight: 600;
  margin: 0;
  padding-top: 0.2rem;
  letter-spacing: 0.02em;
  display: inline-block;
  align-self: start;
}
.tl-body {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.tl-company {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.38);
  margin: 0;
}
.tl-role {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  margin: 0;
}
.tl-desc {
  font-size: 0.88rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.45);
  margin: 0.25rem 0 0 0;
}

/* Skills */
.skill-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}
.skill-card {
  background:
    linear-gradient(#0d0d0d, #0d0d0d) padding-box,
    linear-gradient(
      135deg,
      rgba(249, 115, 22, 0.22),
      rgba(236, 72, 153, 0.22),
      rgba(99, 102, 241, 0.22)
    )
    border-box;
  border: 1px solid transparent;
  border-radius: 14px;
  padding: 1.75rem;
  transition:
    transform 0.3s ease,
    box-shadow 0.3s ease;
}
.skill-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 56px rgba(0, 0, 0, 0.4);
}
.skill-title {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 0.75rem 0;
}
.skill-text {
  font-size: 0.88rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.45);
  margin: 0;
}

/* Qualifications */
.qual-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.qual-group {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 2rem;
  padding: 1.5rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.05);
  align-items: start;
}
.qual-group:last-child {
  border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}
.qual-category {
  font-family: "Bodoni Moda", serif;
  font-style: italic;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  background: linear-gradient(135deg, #f97316, #ec4899);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  /* biome-ignore lint/nursery/useBaseline: gradient text is widely supported */
  background-clip: text;
  margin: 0;
  padding-top: 0.15rem;
  display: inline-block;
}
.qual-items {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.qual-items li {
  font-size: 0.92rem;
  color: rgba(255, 255, 255, 0.7);
}

@media (max-width: 640px) {
  .hero {
    padding: 5rem 1.25rem 4rem;
  }
  .section {
    padding: 3.5rem 1.25rem;
  }
  .tl-item {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  .qual-group {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .skill-list {
    grid-template-columns: 1fr;
  }
}
</style>
