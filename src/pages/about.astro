---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_TITLE } from "../consts";

export const prerender = true;
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={`代表紹介 | ${SITE_TITLE}`}
      description="株式会社イロドア 代表取締役 大貫 理の経歴・プロフィールページです。"
    />
  </head>
  <body>
    <Header />

    <main>
      <!-- Hero -->
      <section class="hero">
        <p class="hero-label">REPRESENTATIVE</p>
        <h1 class="hero-name"><span class="name-cursive">Aya Ohnuki</span></h1>
        <p class="hero-title">代表取締役 / 株式会社イロドア</p>
        <p class="hero-bio">
          アパレル及び美容業界において20年以上にわたり、プレイヤー・指導者・経営者の視点から実績を積む。2024年、株式会社イロドアを設立。ホスピタリティコンサルティング事業と不動産サブリース事業の二軸で事業を推進している。
        </p>
      </section>

      <!-- Career Timeline -->
      <section class="section">
        <div class="section-inner">
          <p class="tag">CAREER</p>
          <h2 class="section-title">職務経歴</h2>
          <ul class="timeline">
            <li class="tl-item">
              <p class="tl-period">2024年〜現在</p>
              <div class="tl-body">
                <p class="tl-company">株式会社イロドア</p>
                <p class="tl-role">代表取締役</p>
                <p class="tl-desc">
                  ホスピタリティコンサルティング事業・不動産サブリース事業を両輪に会社経営を推進。
                </p>
              </div>
            </li>
            <li class="tl-item">
              <p class="tl-period">2023年6月〜2024年5月</p>
              <div class="tl-body">
                <p class="tl-company">株式会社拓要 ネイルサロンアンドヴァ</p>
                <p class="tl-role">店長</p>
                <p class="tl-desc">
                  店舗全体の経営・運営管理、スタッフ育成、売上・予実管理を担当。
                </p>
              </div>
            </li>
            <li class="tl-item">
              <p class="tl-period">2009年5月〜2023年5月</p>
              <div class="tl-body">
                <p class="tl-company">株式会社シープール 等</p>
                <p class="tl-role">チーフネイリスト / 育成責任者</p>
                <p class="tl-desc">
                  銀座・麻布十番エリアにて勤務。後進の技術指導・育成を担い、高付加価値サービスを提供。
                </p>
              </div>
            </li>
            <li class="tl-item">
              <p class="tl-period">2001年3月〜2009年4月</p>
              <div class="tl-body">
                <p class="tl-company">株式会社ワールド 等</p>
                <p class="tl-role">アパレル販売</p>
                <p class="tl-desc">
                  アパレル業界での販売・接客を経験。ホスピタリティの基礎を培う。
                </p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <!-- Skills -->
      <section class="section">
        <div class="section-inner">
          <p class="tag">SKILLS</p>
          <h2 class="section-title">専門スキルと経験</h2>
          <ul class="skill-list">
            <li class="skill-card">
              <h3 class="skill-title">店舗経営・マネジメント</h3>
              <p class="skill-text">
                事業計画、売上・予実管理、人材マネジメント、マーケティング戦略の立案・実行。
              </p>
            </li>
            <li class="skill-card">
              <h3 class="skill-title">美容分野の専門性と指導力</h3>
              <p class="skill-text">
                銀座・麻布十番エリアでのチーフ経験。後進の技術指導・育成実績。ネイル・パーソナルカラー・アロマテラピーの知見を統合した高付加価値提案。
              </p>
            </li>
          </ul>
        </div>
      </section>

      <!-- Qualifications -->
      <section class="section">
        <div class="section-inner">
          <p class="tag">QUALIFICATIONS</p>
          <h2 class="section-title">保有資格</h2>
          <ul class="qual-list">
            <li class="qual-group">
              <p class="qual-category">ネイル</p>
              <ul class="qual-items">
                <li>JNEネイリスト技能検定 1級</li>
                <li>JNAジェルネイル技能検定 上級</li>
              </ul>
            </li>
            <li class="qual-group">
              <p class="qual-category">カラー</p>
              <ul class="qual-items">
                <li>パーソナルカラリスト検定 2級</li>
                <li>色彩検定 2級</li>
              </ul>
            </li>
            <li class="qual-group">
              <p class="qual-category">その他</p>
              <ul class="qual-items">
                <li>AEAJアロマテラピー検定 1級</li>
              </ul>
            </li>
          </ul>
        </div>
      </section>
    </main>

    <Footer />
  </body>
</html>

<style>
@import url("https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap");
:global(html) {
  background: #0a0a0a;
}
:global(body) {
  background: #0a0a0a;
  color: #e8e8e8;
}
:global(:root) {
  --header-bg: #0a0a0a;
  --header-border: rgba(255, 255, 255, 0.08);
  --header-text: #fff;
  --nav-text: rgba(255, 255, 255, 0.6);
  --nav-text-active: #fff;
  --nav-accent: #7c6fff;
  --footer-bg: #0a0a0a;
  --footer-border: rgba(255, 255, 255, 0.06);
  --footer-text: rgba(255, 255, 255, 0.35);
}

main {
  width: 100%;
  max-width: 100%;
  margin: 0;
  padding: 0;
}

/* Hero */
.hero {
  padding: 7rem 2rem 6rem;
  max-width: 960px;
  margin: 0 auto;
}
.hero-label {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #7c6fff;
  margin: 0 0 2rem 0;
}
.hero-name {
  font-size: clamp(2.5rem, 8vw, 4.5rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 0.5rem 0;
  line-height: 1.2;
}
.name-cursive {
  font-family: "Great Vibes", cursive;
  font-weight: 400;
  letter-spacing: 0.02em;
}
.hero-title {
  font-size: 0.95rem;
  color: rgba(255, 255, 255, 0.45);
  margin: 0 0 2rem 0;
  letter-spacing: 0.04em;
}
.hero-bio {
  font-size: 1rem;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.6);
  margin: 0;
  max-width: 600px;
}

/* Sections */
.section {
  padding: 5rem 2rem;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}
.section-inner {
  max-width: 960px;
  margin: 0 auto;
}
.tag {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.22em;
  color: #7c6fff;
  margin: 0 0 1.25rem 0;
}
.section-title {
  font-size: clamp(1.5rem, 4vw, 2.2rem);
  font-weight: 700;
  color: #fff;
  margin: 0 0 3rem 0;
  letter-spacing: -0.01em;
}

/* Timeline */
.timeline {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.tl-item {
  display: grid;
  grid-template-columns: 200px 1fr;
  gap: 2rem;
  padding: 2rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
}
.tl-item:last-child {
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.tl-period {
  font-size: 0.8rem;
  color: #7c6fff;
  font-weight: 600;
  margin: 0;
  padding-top: 0.2rem;
  letter-spacing: 0.02em;
}
.tl-body {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}
.tl-company {
  font-size: 0.85rem;
  color: rgba(255, 255, 255, 0.45);
  margin: 0;
}
.tl-role {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  margin: 0;
}
.tl-desc {
  font-size: 0.88rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.5);
  margin: 0.25rem 0 0 0;
}

/* Skills */
.skill-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1.5rem;
}
.skill-card {
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 12px;
  padding: 1.75rem;
}
.skill-title {
  font-size: 1rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 0.75rem 0;
}
.skill-text {
  font-size: 0.88rem;
  line-height: 1.8;
  color: rgba(255, 255, 255, 0.5);
  margin: 0;
}

/* Qualifications */
.qual-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
}
.qual-group {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 2rem;
  padding: 1.5rem 0;
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  align-items: start;
}
.qual-group:last-child {
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.qual-category {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  color: #7c6fff;
  margin: 0;
  padding-top: 0.15rem;
}
.qual-items {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
}
.qual-items li {
  font-size: 0.92rem;
  color: rgba(255, 255, 255, 0.75);
}

@media (max-width: 640px) {
  .hero {
    padding: 5rem 1.25rem 4rem;
  }
  .section {
    padding: 3.5rem 1.25rem;
  }
  .tl-item {
    grid-template-columns: 1fr;
    gap: 0.5rem;
  }
  .qual-group {
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  .skill-list {
    grid-template-columns: 1fr;
  }
}
</style>
